{
  "manifest_version": 3,
  "name": "Wingman AI",
  "version": "1.0.0",
  "description": "AI-powered smart reply assistant for WhatsApp & Instagram",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://www.instagram.com/*",
    "http://localhost:8000/*",
    "https://api.wingman-ai.com/*"
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.ts"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content/whatsapp/extractor.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/direct/*"],
      "js": ["src/content/instagram/extractor.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
