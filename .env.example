# Wingman AI Environment Configuration Template

# Server settings
ENVIRONMENT=development
DEBUG=true
PORT=8000
HOST=0.0.0.0

# CORS Allowed Origins (comma-separated list)
ALLOWED_ORIGINS=chrome-extension://*,http://localhost:3000,http://localhost:5173

# Database configuration (Postgres URL)
DATABASE_URL=postgresql+asyncpg://wingman:wingman@localhost:5432/wingman_db

# Redis URL for rate limiting and cache
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# JWT Auth Secrets (Run `openssl rand -hex 64` or similar to generate a strong key)
SECRET_KEY=change-this-to-a-very-secure-secret-key-for-jwt-tokens
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI / NVIDIA LLM details
OPENAI_BASE_URL=https://nim.api.nvidia.com/v1
OPENAI_API_KEY=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
OPENAI_MODEL=nicoboss/DeepSeek-R1-Distill-Qwen-32B-Uncensored
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.5
OPENAI_TIMEOUT_SECONDS=30

# Logging configurations (json | text)
LOG_LEVEL=INFO
LOG_FORMAT=text
