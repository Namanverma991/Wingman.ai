# ── Application ──────────────────────────────────────────────────────
APP_NAME=Wingman AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=chrome-extension://*,http://localhost:3000,http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wingman:wingman@localhost:5432/wingman_db

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── JWT ──────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI / NVIDIA LLM details
OPENAI_BASE_URL=https://nim.api.nvidia.com/v1
OPENAI_API_KEY=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
OPENAI_MODEL=nicoboss/DeepSeek-R1-Distill-Qwen-32B-Uncensored
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.5
OPENAI_TIMEOUT_SECONDS=30

# ── Usage ────────────────────────────────────────────────────────────
FREE_TIER_DAILY_CREDITS=10
PRO_TIER_DAILY_CREDITS=200
CREDITS_PER_REPLY=1

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
